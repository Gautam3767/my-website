{
  "name": "personal_website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env -- tinacms dev -c \"vite\"",
    "dev:vite": "vite",
    "build": "dotenv -e .env -- bash -c \"tinacms build && vite build\"",
    "build:local": "tinacms build --local --skip-cloud-checks --skip-search-index && vite build",
    "preview": "vite preview",
    "migrate-content": "node scripts/migrate-content.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tinacms/cli": "^2.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tinacms": "^3.8.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
